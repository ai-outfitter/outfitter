#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
SOURCE_HOME="${HOME:-}"
PROJECT_DIR="$(pwd)"
SETUP_SOURCE="${1:-}"

usage() {
  cat <<'USAGE'
Usage: bin/dev-tmp-home [setup-source]

Launch this Outfitter checkout with a fresh temporary HOME.

With no setup source, this exercises the normal first-run flow: `outfitter run`
creates user settings, syncs default profiles from GitHub, runs welcome, and
then launches the selected/default profile.

With a setup source, this exercises setup-source flow: `outfitter setup
<setup-source>`. The setup source may be a local Git repository path or a remote
Git URL.
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

if [[ "${SETUP_SOURCE:-}" == "-h" || "${SETUP_SOURCE:-}" == "--help" ]]; then
  usage
  exit 0
fi

[[ $# -le 1 ]] || die "expected at most one setup source argument"

DEV_HOME="$(mktemp -d -t outfitter-dev-home.XXXXXX)"

cleanup() {
  rm -rf -- "$DEV_HOME"
}
trap cleanup EXIT

mkdir -p "$DEV_HOME/.pi/agent/cache" \
  "$DEV_HOME/.pi/agent/git" \
  "$DEV_HOME/.pi/agent/npm" \
  "$DEV_HOME/.pi/agent/plugins" \
  "$DEV_HOME/.pi/agent/sessions" \
  "$DEV_HOME/.pi/agent/tmp"

cat > "$DEV_HOME/.pi/agent/settings.json" <<'JSON'
{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "xhigh"
}
JSON
printf '{"providers":{}}\n' > "$DEV_HOME/.pi/agent/models.json"
printf '{}\n' > "$DEV_HOME/.pi/agent/mcp.json"

if [[ -n "$SOURCE_HOME" && -f "$SOURCE_HOME/.pi/agent/auth.json" ]]; then
  install -m 600 "$SOURCE_HOME/.pi/agent/auth.json" "$DEV_HOME/.pi/agent/auth.json"
else
  printf '{}\n' > "$DEV_HOME/.pi/agent/auth.json"
  chmod 600 "$DEV_HOME/.pi/agent/auth.json"
fi

npm --prefix "$REPO_ROOT" run build

echo "Outfitter dev HOME: $DEV_HOME"
echo "Project dir:       $PROJECT_DIR"
if [[ -n "$SETUP_SOURCE" ]]; then
  echo "Setup source:      $SETUP_SOURCE"
else
  echo "Setup source:      GitHub default profiles via outfitter first-run setup"
fi
if grep -q '"openai-codex"' "$DEV_HOME/.pi/agent/auth.json" 2>/dev/null; then
  echo "Pi auth:           copied openai-codex auth from $SOURCE_HOME"
elif [[ -n "${OPENAI_API_KEY:-}" ]]; then
  echo "Pi auth:           using OPENAI_API_KEY from environment"
else
  echo "Pi auth:           no openai-codex auth found; Pi may ask you to log in" >&2
fi

declare -a launch_cmd
if [[ -n "$SETUP_SOURCE" ]]; then
  launch_cmd=(node "$REPO_ROOT/dist/cli.js" setup "$SETUP_SOURCE")
else
  launch_cmd=(node "$REPO_ROOT/dist/cli.js" run)
fi

cd -- "$PROJECT_DIR"
HOME="$DEV_HOME" "${launch_cmd[@]}"
