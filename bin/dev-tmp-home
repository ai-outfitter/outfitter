#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"
SOURCE_HOME="${HOME:-}"
SOURCE_CWD="$(pwd)"
FRESH_PI=0
SETUP_SOURCE=""

usage() {
  cat <<'USAGE'
Usage: bin/dev-tmp-home [--fresh-pi] [setup-source]

Launch this Outfitter checkout with a fresh temporary HOME and project
directory.

With no setup source, this exercises the normal first-run flow: `outfitter run`
creates user settings, syncs default profiles from GitHub, runs welcome, and
then launches the selected/default profile.

With a setup source, this exercises setup-source flow: `outfitter setup
<setup-source>`. The setup source may be a local Git repository path or a remote
Git URL. Local setup-source paths are resolved before switching to the temporary
project directory.

By default, the temporary HOME is seeded with the current user's Pi auth, model,
and settings files when they exist. Use --fresh-pi to leave Pi auth/model state
empty so provider/model login bootstrap can be tested.
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --fresh-pi)
      [[ "$FRESH_PI" -eq 0 ]] || die "--fresh-pi was provided more than once"
      FRESH_PI=1
      shift
      ;;
    --*)
      die "unknown option: $1"
      ;;
    *)
      [[ -z "$SETUP_SOURCE" ]] || die "expected at most one setup source argument"
      SETUP_SOURCE="$1"
      shift
      ;;
  esac
done

if [[ -n "$SETUP_SOURCE" && -d "$SETUP_SOURCE" ]]; then
  SETUP_SOURCE="$(cd -- "$SETUP_SOURCE" && pwd)"
fi

DEV_HOME="$(mktemp -d -t outfitter-dev-home.XXXXXX)"
PROJECT_DIR="$DEV_HOME/project"

cleanup() {
  rm -rf -- "$DEV_HOME"
}
trap cleanup EXIT

PI_AGENT_DIR="$DEV_HOME/.pi/agent"
SOURCE_PI_AGENT_DIR="$SOURCE_HOME/.pi/agent"

mkdir -p "$PROJECT_DIR" \
  "$PI_AGENT_DIR/cache" \
  "$PI_AGENT_DIR/git" \
  "$PI_AGENT_DIR/npm" \
  "$PI_AGENT_DIR/plugins" \
  "$PI_AGENT_DIR/sessions" \
  "$PI_AGENT_DIR/tmp"

write_default_pi_settings() {
  cat > "$PI_AGENT_DIR/settings.json" <<'JSON'
{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "xhigh"
}
JSON
}

copy_pi_file_or_write_default() {
  local filename="$1"
  local fallback_content="$2"
  local target_path="$PI_AGENT_DIR/$filename"
  local source_path="$SOURCE_PI_AGENT_DIR/$filename"

  if [[ -n "$SOURCE_HOME" && -f "$source_path" ]]; then
    cp -- "$source_path" "$target_path"
    return 0
  fi

  printf '%s\n' "$fallback_content" > "$target_path"
  return 1
}

seed_piggyback_pi_state() {
  if [[ -n "$SOURCE_HOME" && -f "$SOURCE_PI_AGENT_DIR/auth.json" ]]; then
    install -m 600 "$SOURCE_PI_AGENT_DIR/auth.json" "$PI_AGENT_DIR/auth.json"
  else
    printf '{}\n' > "$PI_AGENT_DIR/auth.json"
    chmod 600 "$PI_AGENT_DIR/auth.json"
  fi

  copy_pi_file_or_write_default models.json '{"providers":{}}' >/dev/null || true
  copy_pi_file_or_write_default mcp.json '{}' >/dev/null || true

  if [[ -n "$SOURCE_HOME" && -f "$SOURCE_PI_AGENT_DIR/settings.json" ]]; then
    cp -- "$SOURCE_PI_AGENT_DIR/settings.json" "$PI_AGENT_DIR/settings.json"
  else
    write_default_pi_settings
  fi
}

seed_fresh_pi_state() {
  printf '{}\n' > "$PI_AGENT_DIR/auth.json"
  chmod 600 "$PI_AGENT_DIR/auth.json"
  printf '{"providers":{}}\n' > "$PI_AGENT_DIR/models.json"
  printf '{}\n' > "$PI_AGENT_DIR/mcp.json"
  printf '{}\n' > "$PI_AGENT_DIR/settings.json"
}

if [[ "$FRESH_PI" -eq 1 ]]; then
  seed_fresh_pi_state
else
  seed_piggyback_pi_state
fi

npm --prefix "$REPO_ROOT" run build

echo "Outfitter dev HOME: $DEV_HOME"
echo "Source cwd:        $SOURCE_CWD"
echo "Project dir:       $PROJECT_DIR"
if [[ -n "$SETUP_SOURCE" ]]; then
  echo "Setup source:      $SETUP_SOURCE"
else
  echo "Setup source:      GitHub default profiles via outfitter first-run setup"
fi
if [[ "$FRESH_PI" -eq 1 ]]; then
  echo "Pi state:          fresh unauthenticated (--fresh-pi); provider bootstrap should run"
else
  echo "Pi state:          piggybacked from $SOURCE_HOME/.pi/agent when files exist"
fi
if grep -q '"openai-codex"' "$PI_AGENT_DIR/auth.json" 2>/dev/null; then
  echo "Pi auth:           copied openai-codex auth from $SOURCE_HOME"
elif [[ "$FRESH_PI" -eq 1 ]]; then
  echo "Pi auth:           empty fresh auth.json"
elif [[ -n "${OPENAI_API_KEY:-}" ]]; then
  echo "Pi auth:           no auth.json copied; OPENAI_API_KEY remains available from environment"
else
  echo "Pi auth:           no openai-codex auth found; Pi may ask you to log in" >&2
fi

declare -a launch_cmd
if [[ -n "$SETUP_SOURCE" ]]; then
  launch_cmd=(node "$REPO_ROOT/dist/cli.js" setup "$SETUP_SOURCE")
else
  launch_cmd=(node "$REPO_ROOT/dist/cli.js" run)
fi

cd -- "$PROJECT_DIR"
HOME="$DEV_HOME" "${launch_cmd[@]}"
