{
  "name": "@ai-outfitter/root",
  "private": true,
  "version": "0.8.0",
  "description": "Workspace root for Outfitter packages.",
  "type": "module",
  "workspaces": [
    "code/cli",
    "code/pi-extension"
  ],
  "scripts": {
    "build": "bun --cwd=code/cli run build",
    "prepare": "bun --cwd=code/cli run build",
    "dev_install": "bun --cwd=code/cli run dev_install",
    "docs:dev": "bun --cwd=code/doc_site run dev --",
    "docs:build": "bun --cwd=code/doc_site run build",
    "docs:start": "bun --cwd=code/doc_site run start --",
    "docs:lint": "bun --cwd=code/doc_site run lint",
    "docs:ci": "cd code/doc_site && bun install --frozen-lockfile && cd ../.. && bun run docs:lint && bun run docs:build",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun --cwd=code/cli run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "test": "bun --cwd=code/cli run test",
    "coverage": "bun --cwd=code/cli run coverage",
    "snapper:format": "bun scripts/run-snapper.ts --git-md -i",
    "check": "bun run snapper:format && biome check --write . && bun run coverage",
    "check-ci": "biome ci . && bun run typecheck && bun run coverage && bun run docs:ci"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0"
  },
  "engines": {
    "node": ">=22.19.0",
    "bun": ">=1.3.0"
  },
  "trustedDependencies": [
    "@ai-outfitter/outfitter",
    "protobufjs"
  ]
}
